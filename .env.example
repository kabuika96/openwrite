# Backend HTTP/WebSocket server
OPENWRITE_BACKEND_PORT=8787
OPENWRITE_BACKEND_HOST=0.0.0.0
OPENWRITE_STATE_PATH=./data/openwrite-state.json

# Optional: open this vault on startup instead of showing the vault picker.
# OPENWRITE_VAULT_PATH=./data/workspace

# Frontend dev server
OPENWRITE_FRONTEND_PORT=5173
OPENWRITE_FRONTEND_HOST=0.0.0.0

# Optional: comma-separated hostnames Vite should accept during local dev.
# OPENWRITE_ALLOWED_HOSTS=openwrite.local

# Optional: override frontend proxy targets.
# OPENWRITE_BACKEND_HTTP_ORIGIN=http://127.0.0.1:8787
# OPENWRITE_BACKEND_WS_ORIGIN=ws://127.0.0.1:8787
